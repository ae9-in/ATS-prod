generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  RECRUITER
  INTERVIEWER

  @@map("user_role")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING

  @@map("user_status")
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED

  @@map("candidate_status")
}

enum InterviewMode {
  ONLINE
  OFFLINE
  PHONE

  @@map("interview_mode")
}

enum InterviewResult {
  PENDING
  PASS
  FAIL
  HOLD

  @@map("interview_result")
}

enum ApplicationStatus {
  IN_PIPELINE
  SELECTED
  REJECTED
  JOINED
  WITHDRAWN

  @@map("application_status")
}

model User {
  id                String          @id @default(uuid()) @db.Uuid
  fullName          String          @map("full_name") @db.VarChar(120)
  email             String          @db.VarChar(255)
  phone             String?         @db.VarChar(20)
  passwordHash      String          @map("password_hash")
  role              UserRole
  status            UserStatus      @default(ACTIVE)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  jobsCreated       Job[]
  candidatesCreated Candidate[]
  interviewsCreated Interview[]     @relation("InterviewCreatedBy")
  interviewsTaken   Interview[]     @relation("InterviewInterviewer")
  feedbackSubmitted InterviewFeedback[]
  pipelineEvents    PipelineEvent[]
  auditLogs         AuditLog[]      @relation("AuditActor")
  filesUploaded     FileMeta[]        @relation("FileUploadedBy")
  profilePhotoFileId String?          @map("profile_photo_file_id") @db.Uuid
  profilePhotoFile   FileMeta?         @relation("UserProfilePhoto", fields: [profilePhotoFileId], references: [id])

  @@index([email])
  @@map("users")
}

model Job {
  id             String          @id @default(uuid()) @db.Uuid
  title          String          @db.VarChar(150)
  department     String?         @db.VarChar(120)
  location       String?         @db.VarChar(120)
  employmentType String?         @map("employment_type") @db.VarChar(40)
  experienceMin  Int?            @map("experience_min")
  experienceMax  Int?            @map("experience_max")
  openingsCount  Int             @default(1) @map("openings_count")
  description    String?
  isActive       Boolean         @default(true) @map("is_active")
  createdById    String          @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      User            @relation(fields: [createdById], references: [id])
  applications   Application[]
  pipelineStages PipelineStage[]

  @@map("jobs")
}

model Candidate {
  id                   String             @id @default(uuid()) @db.Uuid
  fullName             String             @map("full_name") @db.VarChar(120)
  email                String?            @db.VarChar(255)
  phone                String?            @db.VarChar(20)
  totalExperienceYears Decimal?           @map("total_experience_years") @db.Decimal(4, 1)
  currentCompany       String?            @map("current_company") @db.VarChar(150)
  currentCtc           Decimal?           @map("current_ctc") @db.Decimal(12, 2)
  expectedCtc          Decimal?           @map("expected_ctc") @db.Decimal(12, 2)
  noticePeriodDays     Int?               @map("notice_period_days")
  source               String?            @db.VarChar(80)
  category             String?            @default("Company") @db.VarChar(50)
  status               CandidateStatus    @default(ACTIVE)
  resumeFileId         String?            @map("resume_file_id") @db.Uuid
  profilePhotoFileId   String?            @map("profile_photo_file_id") @db.Uuid
  createdById          String             @map("created_by") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  resumeFile           FileMeta?          @relation("CandidateResumeFile", fields: [resumeFileId], references: [id])
  profilePhotoFile     FileMeta?          @relation("CandidateProfilePhoto", fields: [profilePhotoFileId], references: [id])
  createdBy            User               @relation(fields: [createdById], references: [id])
  skills               CandidateSkill[]
  education            CandidateEducation[]
  applications         Application[]
  customFieldValues    CustomFieldValue[]

  @@index([fullName])
  @@index([email])
  @@index([phone])
  @@index([category])
  @@map("candidates")
}

model CandidateSkill {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @map("candidate_id") @db.Uuid
  skillName   String    @map("skill_name") @db.VarChar(80)
  proficiency Int?
  years       Decimal?  @db.Decimal(4, 1)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([skillName])
  @@map("candidate_skills")
}

model CandidateEducation {
  id             String    @id @default(uuid()) @db.Uuid
  candidateId    String    @map("candidate_id") @db.Uuid
  degree         String?   @db.VarChar(120)
  institution    String?   @db.VarChar(180)
  specialization String?   @db.VarChar(120)
  startYear      Int?      @map("start_year")
  endYear        Int?      @map("end_year")
  score          String?   @db.VarChar(40)
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_education")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  candidateId     String            @map("candidate_id") @db.Uuid
  jobId           String            @map("job_id") @db.Uuid
  status          ApplicationStatus @default(IN_PIPELINE)
  currentStageId  String?           @map("current_stage_id") @db.Uuid
  shortlisted     Boolean           @default(false)
  rejectionReason String?           @map("rejection_reason")
  joinedOn        DateTime?         @map("joined_on") @db.Date
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  candidate       Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  currentStage    PipelineStage?    @relation("ApplicationCurrentStage", fields: [currentStageId], references: [id])
  pipelineEvents  PipelineEvent[]
  interviews      Interview[]
  customValues    CustomFieldValue[]

  @@unique([candidateId, jobId])
  @@index([jobId, status])
  @@index([currentStageId])
  @@index([shortlisted])
  @@map("applications")
}

model PipelineStage {
  id                String          @id @default(uuid()) @db.Uuid
  jobId             String?         @map("job_id") @db.Uuid
  name              String          @db.VarChar(60)
  sortOrder         Int             @map("sort_order")
  isTerminal        Boolean         @default(false) @map("is_terminal")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  job               Job?            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications      Application[]   @relation("ApplicationCurrentStage")
  eventsFrom        PipelineEvent[] @relation("PipelineFromStage")
  eventsTo          PipelineEvent[] @relation("PipelineToStage")

  @@unique([jobId, sortOrder])
  @@map("pipeline_stages")
}

model PipelineEvent {
  id            String         @id @default(uuid()) @db.Uuid
  applicationId String         @map("application_id") @db.Uuid
  fromStageId   String?        @map("from_stage_id") @db.Uuid
  toStageId     String?        @map("to_stage_id") @db.Uuid
  remark        String?
  feedback      String?
  movedById     String         @map("moved_by") @db.Uuid
  movedAt       DateTime       @default(now()) @map("moved_at") @db.Timestamptz(6)
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStage     PipelineStage? @relation("PipelineFromStage", fields: [fromStageId], references: [id])
  toStage       PipelineStage? @relation("PipelineToStage", fields: [toStageId], references: [id])
  movedBy       User           @relation(fields: [movedById], references: [id])

  @@index([applicationId, movedAt(sort: Desc)])
  @@map("pipeline_events")
}

model Interview {
  id                         String            @id @default(uuid()) @db.Uuid
  applicationId              String            @map("application_id") @db.Uuid
  roundNo                    Int               @map("round_no")
  round                      String?           @db.VarChar(50)
  scheduledStart             DateTime          @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd               DateTime?         @map("scheduled_end") @db.Timestamptz(6)
  mode                       InterviewMode
  meetingLink                String?           @map("meeting_link")
  result                     InterviewResult   @default(PENDING)
  mandatoryFeedbackSubmitted Boolean           @default(false) @map("mandatory_feedback_submitted")
  voiceRecordingFileId       String?           @map("voice_recording_file_id") @db.Uuid
  createdById                String            @map("created_by") @db.Uuid
  createdAt                  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  application                Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewers               User[]            @relation("InterviewInterviewer")
  createdBy                  User              @relation("InterviewCreatedBy", fields: [createdById], references: [id])
  voiceRecordingFile         FileMeta?         @relation("InterviewRecordingFile", fields: [voiceRecordingFileId], references: [id])
  feedbacks                  InterviewFeedback[]

  @@index([scheduledStart])
  @@map("interviews")
}

model InterviewFeedback {
  id                 String          @id @default(uuid()) @db.Uuid
  interviewId        String          @map("interview_id") @db.Uuid
  technicalRating    Int             @map("technical_rating")
  communicationRating Int            @map("communication_rating")
  cultureFitRating   Int             @map("culture_fit_rating")
  strengths          String
  concerns           String
  recommendation     InterviewResult
  overallComments    String          @map("overall_comments")
  submittedById      String          @map("submitted_by") @db.Uuid
  submittedAt        DateTime        @default(now()) @map("submitted_at") @db.Timestamptz(6)
  interview          Interview       @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  submittedBy        User            @relation(fields: [submittedById], references: [id])

  @@unique([interviewId, submittedById])
  @@map("interview_feedback")
}

model FileMeta {
  id                     String       @id @default(uuid()) @db.Uuid
  storageKey             String       @unique @map("storage_key")
  originalName           String       @map("original_name") @db.VarChar(255)
  mimeType               String       @map("mime_type") @db.VarChar(120)
  sizeBytes              BigInt       @map("size_bytes")
  uploadedById           String?      @map("uploaded_by") @db.Uuid
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  uploadedBy             User?        @relation("FileUploadedBy", fields: [uploadedById], references: [id])
  candidateResumeFor     Candidate[]  @relation("CandidateResumeFile")
  candidateProfilePhotoFor Candidate[]  @relation("CandidateProfilePhoto")
  userProfilePhotoFor      User[]       @relation("UserProfilePhoto")
  interviewRecordingFor  Interview[]  @relation("InterviewRecordingFile")

  @@map("files")
}

model CustomFieldDefinition {
  id            String             @id @default(uuid()) @db.Uuid
  entityType    String             @map("entity_type") @db.VarChar(40)
  fieldKey      String             @map("field_key") @db.VarChar(80)
  fieldLabel    String             @map("field_label") @db.VarChar(120)
  fieldType     String             @map("field_type") @db.VarChar(40)
  isRequired    Boolean            @default(false) @map("is_required")
  optionsJson   Json?              @map("options_json")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  values        CustomFieldValue[]

  @@unique([entityType, fieldKey])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id                 String                @id @default(uuid()) @db.Uuid
  fieldDefinitionId  String                @map("field_definition_id") @db.Uuid
  candidateId        String?               @map("candidate_id") @db.Uuid
  applicationId      String?               @map("application_id") @db.Uuid
  valueText          String?               @map("value_text")
  valueJson          Json?                 @map("value_json")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  fieldDefinition    CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  candidate          Candidate?            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application        Application?          @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("custom_field_values")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  actorUserId String?   @map("actor_user_id") @db.Uuid
  action      String    @db.VarChar(80)
  entityType  String    @map("entity_type") @db.VarChar(40)
  entityId    String?   @map("entity_id") @db.Uuid
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       User?     @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
